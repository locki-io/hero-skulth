# hero-skulth — CONFIG concern (never rotates; radius: config; agent-touchable per Lifecycle Law)
# Copy to .env.config at the repo root; the root .gitignore seals it out of history.
# Load per layer: set -a && source .env.config && set +a

# Arc testnet RPC — primary source: docs.arc.io (chain id 5042002)
SKULTH_ARC_RPC_URL=https://rpc.testnet.arc.network

# skulþ data-plane endpoint for the regime seam (pod/regime.py).
# Mac local: http://localhost:5002 · from a container: http://host.docker.internal:5002
SKULTH_API_URL=http://localhost:5002

# Billing epoch length in seconds: 3600 = one billing day per hour (demo acceleration).
# The twins compose file overrides this per-service (15 s) for the fast demo.
SKULTH_POD_EPOCH_SECONDS=3600

#jnxmas
OPERATOR_WALLET=
