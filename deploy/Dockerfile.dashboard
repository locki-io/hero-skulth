# hero-skulth face — streamlit (Apache-2.0) rides only in THIS image;
# the twins stay stdlib-pure.
FROM python:3.13-slim
RUN pip install --no-cache-dir streamlit
WORKDIR /app
COPY pod/ pod/
ENV PYTHONUNBUFFERED=1
CMD ["streamlit", "run", "pod/dashboard.py", "--server.headless", "true", "--server.port", "8501", "--server.address", "0.0.0.0"]
